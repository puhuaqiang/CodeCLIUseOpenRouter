# OpenRouter 配置
# 优先使用系统环境变量 OPENROUTER_API_KEY
# 如果系统环境变量未设置，则使用此文件中的值
# 
# 设置系统环境变量方法:
#   PowerShell: $env:OPENROUTER_API_KEY = "sk-or-v1-..."
#   CMD:        set OPENROUTER_API_KEY=sk-or-v1-...
#   Linux/Mac:  export OPENROUTER_API_KEY=sk-or-v1-...
#
# 从 https://openrouter.ai/keys 获取 API Key

OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter API 基础 URL (可选，默认使用官方地址)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ==========================================
# Claude 代理配置 (Anthropic 格式)
# ==========================================
PROXY_HOST=127.0.0.1
PROXY_PORT=8080

# ==========================================
# Gemini 代理配置 (Gemini 格式)
# ==========================================
GEMINI_PROXY_HOST=127.0.0.1
GEMINI_PROXY_PORT=8081
